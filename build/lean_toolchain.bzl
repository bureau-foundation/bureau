"""Module extension for downloading the Lean 4 toolchain from official releases.

Downloads a platform-specific Lean release tarball during Bazel's loading phase
and caches it as a Bazel repository. The toolchain includes lean (compiler),
lake (build tool), leanc (C backend), and the precompiled standard library.

Usage in MODULE.bazel:

    lean_toolchain = use_extension("//build:lean_toolchain.bzl", "lean_toolchain")
    lean_toolchain.release(
        name = "lean4",
        version = "4.28.0",
        sha256 = {"linux-x86_64": "abc123...", "darwin-aarch64": "def456..."},
    )
    use_repo(lean_toolchain, "lean4")

Then in BUILD files:

    sh_test(
        ...
        data = ["@lean4//:toolchain_root"],
        env = {"LEAN_TOOLCHAIN_ROOT": "$(rlocationpath @lean4//:toolchain_root)"},
    )

The test script reads the toolchain_root file to find the extracted
toolchain directory, then adds its bin/ to PATH. The entire 10K+ file
toolchain is NOT placed in the runfiles tree — only the single marker
file. The test reaches the toolchain via its absolute path in Bazel's
output base.
"""

# Map (os, arch) to the release tarball naming convention used by leanprover.
# Lean releases use "linux" not "linux-x86_64" for the default x86_64 build,
# and "linux_aarch64" for ARM.
_PLATFORM_MAP = {
    ("linux", "x86_64"): "linux",
    ("linux", "aarch64"): "linux_aarch64",
    ("darwin", "x86_64"): "darwin",
    ("darwin", "aarch64"): "darwin_aarch64",
}

def _detect_platform(repository_ctx):
    """Detect the host platform for selecting the right release tarball."""
    os = repository_ctx.os.name
    if "linux" in os:
        os_key = "linux"
    elif "mac" in os:
        os_key = "darwin"
    else:
        fail("Unsupported OS for Lean toolchain: " + os)

    arch_result = repository_ctx.execute(["uname", "-m"])
    if arch_result.return_code != 0:
        fail("Failed to detect architecture: " + arch_result.stderr)

    arch = arch_result.stdout.strip()

    # Normalize architecture names.
    if arch == "arm64":
        arch = "aarch64"

    platform_key = (os_key, arch)
    release_suffix = _PLATFORM_MAP.get(platform_key)
    if not release_suffix:
        fail("Unsupported platform for Lean toolchain: {os}-{arch}".format(
            os = os_key,
            arch = arch,
        ))

    return os_key, arch, release_suffix

def _lean_toolchain_repo_impl(repository_ctx):
    """Downloads and extracts a Lean 4 release toolchain."""
    version = repository_ctx.attr.version
    sha256_map = repository_ctx.attr.sha256
    os_key, arch, release_suffix = _detect_platform(repository_ctx)

    platform_key = os_key + "-" + arch
    sha256 = sha256_map.get(platform_key)
    if not sha256:
        fail("No sha256 for platform {platform}. Available: {available}".format(
            platform = platform_key,
            available = ", ".join(sha256_map.keys()),
        ))

    filename = "lean-{version}-{suffix}.tar.zst".format(
        version = version,
        suffix = release_suffix,
    )
    url = "https://github.com/leanprover/lean4/releases/download/v{version}/{filename}".format(
        version = version,
        filename = filename,
    )
    strip_prefix = "lean-{version}-{suffix}".format(
        version = version,
        suffix = release_suffix,
    )

    repository_ctx.download_and_extract(
        url = url,
        sha256 = sha256,
        stripPrefix = strip_prefix,
    )

    # Write a marker file containing the toolchain root path. The sh_test
    # declares this single file as data (not the entire toolchain — 10K+
    # files don't work well in Bazel runfiles). The test script reads the
    # marker to find the toolchain directory.
    #
    # This works because repository rules are extracted to a stable path
    # in Bazel's output base. The toolchain directory exists on disk for
    # the entire lifetime of the Bazel server. Writing the absolute path
    # into the marker lets the test script reach the full toolchain
    # (bin/lake, lib/lean/) without Bazel needing to create 10K symlinks
    # in the runfiles tree.
    toolchain_root = str(repository_ctx.path("."))
    repository_ctx.file("toolchain_root", toolchain_root)

    repository_ctx.file("BUILD.bazel", """\
# Generated by //build:lean_toolchain.bzl — do not edit.
#
# Lean 4 toolchain ({version}, {platform}).
# bin/lean, bin/lake, bin/leanc, plus precompiled standard library in lib/lean/.
#
# The toolchain_root file contains the absolute path to the extracted
# toolchain. Tests use this to find lean without Bazel needing to symlink
# the entire 10K+ file toolchain into the runfiles tree.

exports_files(["toolchain_root"])
""".format(version = version, platform = platform_key))

_lean_toolchain_repo = repository_rule(
    implementation = _lean_toolchain_repo_impl,
    attrs = {
        "version": attr.string(
            mandatory = True,
            doc = "Lean 4 release version (e.g. '4.28.0').",
        ),
        "sha256": attr.string_dict(
            mandatory = True,
            doc = "SHA-256 hashes keyed by platform: 'linux-x86_64', 'darwin-aarch64', etc.",
        ),
    },
    doc = "Downloads a Lean 4 release toolchain and makes it available as a filegroup.",
)

def _lean_toolchain_impl(module_ctx):
    """Module extension that creates one repository per lean_toolchain.release() tag."""
    for module in module_ctx.modules:
        for tag in module.tags.release:
            _lean_toolchain_repo(
                name = tag.name,
                version = tag.version,
                sha256 = tag.sha256,
            )

_release_tag = tag_class(
    attrs = {
        "name": attr.string(mandatory = True, doc = "Repository name for use_repo()."),
        "version": attr.string(mandatory = True, doc = "Lean 4 release version."),
        "sha256": attr.string_dict(
            mandatory = True,
            doc = "SHA-256 hashes keyed by platform (e.g. {'linux-x86_64': '...', 'darwin-aarch64': '...'}).",
        ),
    },
    doc = "Declares a Lean 4 release toolchain to download.",
)

lean_toolchain = module_extension(
    implementation = _lean_toolchain_impl,
    tag_classes = {"release": _release_tag},
    doc = "Downloads Lean 4 toolchains from official GitHub releases.",
)
