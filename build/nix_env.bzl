"""Module extension for resolving Nix flake outputs into Bazel repositories.

Runs `nix build` during Bazel's loading phase (where network access is
expected) and caches the resulting store path. The store path is exposed
as a single file that tests and build rules can read. Bazel re-evaluates
only when flake.nix or flake.lock change.

Usage in MODULE.bazel:

    nix_env = use_extension("//build:nix_env.bzl", "nix_env")
    nix_env.build(name = "integration_test_env", attr = "integration-test-env")
    use_repo(nix_env, "integration_test_env")

Then in BUILD files:

    go_test(
        ...
        data = ["@integration_test_env//:store_path"],
        env = {"NIX_ENV_PATH": "$(rlocationpath @integration_test_env//:store_path)"},
    )
"""

def _nix_env_repo_impl(repository_ctx):
    """Repository rule that builds a Nix flake output and records its store path."""

    # Resolve the workspace root from the flake.nix label. Reading these
    # files establishes a dependency: Bazel re-runs this rule when either
    # file changes on disk.
    flake_nix = repository_ctx.path(repository_ctx.attr._flake_nix)
    repository_ctx.path(repository_ctx.attr._flake_lock)
    workspace_root = str(flake_nix.dirname)

    nix = repository_ctx.attr.nix_binary
    flake_ref = ".#" + repository_ctx.attr.attr

    result = repository_ctx.execute(
        [nix, "build", flake_ref, "--print-out-paths", "--no-link"],
        working_directory = workspace_root,
        timeout = 300,
    )
    if result.return_code != 0:
        fail(
            "nix build {ref} failed (exit {code}):\n{stderr}".format(
                ref = flake_ref,
                code = result.return_code,
                stderr = result.stderr,
            ),
        )

    store_path = result.stdout.strip()
    if not store_path:
        fail("nix build {ref} produced empty output".format(ref = flake_ref))

    # Write the store path to a file and expose it as a Bazel target.
    repository_ctx.file("store_path", store_path)
    repository_ctx.file("BUILD.bazel", """\
# Generated by //build:nix_env.bzl — do not edit.
exports_files(["store_path"])
""")

_nix_env_repo = repository_rule(
    implementation = _nix_env_repo_impl,
    attrs = {
        "attr": attr.string(
            mandatory = True,
            doc = "Flake output attribute name (e.g. 'integration-test-env').",
        ),
        "nix_binary": attr.string(
            default = "/nix/var/nix/profiles/default/bin/nix",
            doc = "Absolute path to the nix binary.",
        ),
        "_flake_nix": attr.label(
            default = "//:flake.nix",
            doc = "Flake definition. Changes trigger re-evaluation.",
        ),
        "_flake_lock": attr.label(
            default = "//:flake.lock",
            doc = "Flake lock file. Changes trigger re-evaluation.",
        ),
    },
    # Full host access: needs the nix binary, nix store, and nix daemon socket.
    local = True,
    doc = "Builds a Nix flake output and records its store path.",
)

def _nix_env_impl(module_ctx):
    """Module extension that creates one repository per nix_env.build() tag."""
    for module in module_ctx.modules:
        for tag in module.tags.build:
            _nix_env_repo(
                name = tag.name,
                attr = tag.attr,
                nix_binary = tag.nix_binary,
            )

_build_tag = tag_class(
    attrs = {
        "name": attr.string(mandatory = True, doc = "Repository name for use_repo()."),
        "attr": attr.string(mandatory = True, doc = "Flake output attribute name."),
        "nix_binary": attr.string(
            default = "/nix/var/nix/profiles/default/bin/nix",
            doc = "Absolute path to the nix binary.",
        ),
    },
    doc = "Declares a Nix flake output to resolve during loading.",
)

nix_env = module_extension(
    implementation = _nix_env_impl,
    tag_classes = {"build": _build_tag},
    doc = "Resolves Nix flake outputs into cached Bazel repositories.",
)
