# Example cloudflared local configuration for named tunnels.
#
# For most deployments, connector tokens (configured via the Cloudflare
# dashboard) are simpler. This file is for operators who prefer local
# tunnel config files with path-based routing.
#
# Place this at /etc/cloudflared/config.yml or pass via
# --config flag in the PrincipalAssignment's CommandOverride.

tunnel: bureau-webhooks
credentials-file: /etc/cloudflared/credentials.json

ingress:
  # GitHub webhooks → bridge on port 8642 → github-service http.sock
  - hostname: webhooks.example.com
    path: /github/*
    service: http://localhost:8642

  # Catch-all: reject unmatched requests.
  - service: http_status:404
