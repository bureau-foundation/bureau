#!/usr/bin/env bash
# Copyright 2026 The Bureau Authors
# SPDX-License-Identifier: Apache-2.0
#
# Build and deploy the current worktree to the local Bureau instance.
#
# This script builds bureau-host-env from the current worktree, then
# publishes a BureauVersion state event via "bureau machine upgrade --local".
# The running daemon picks up the new version via /sync and performs an
# atomic exec() transition.
#
# When a dev instance exists (from script/dev-setup), this targets the
# dev instance by default. Use --prod to target the system installation.
#
# Usage:
#   script/dev-deploy [options]
#
# Options:
#   --credential-file FILE   Path to Bureau credentials (auto-detected)
#   --prod                   Target the system (prod) installation instead of dev
#   --dry-run                Build but do not publish the upgrade event
#   --help                   Show this help
#
# Environment variables:
#   BUREAU_CREDENTIAL_FILE       Override default credential file path
#   BUREAU_LAUNCHER_SESSION      Path to launcher session.json (for non-default state dirs)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
DEV_CONFIG_FILE="$REPO_ROOT/deploy/dev/config"

# Defaults.
CREDENTIAL_FILE="${BUREAU_CREDENTIAL_FILE:-}"
FORCE_PROD=false
DRY_RUN=false

usage() {
    sed -n '/^# Usage:/,/^[^#]/p' "$0" | sed 's/^# \?//' | head -n -1
    exit "${1:-0}"
}

# Parse arguments.
while [[ $# -gt 0 ]]; do
    case "$1" in
        --credential-file)
            CREDENTIAL_FILE="$2"
            shift 2
            ;;
        --prod)
            FORCE_PROD=true
            shift
            ;;
        --dry-run)
            DRY_RUN=true
            shift
            ;;
        --help|-h)
            usage 0
            ;;
        -*)
            echo "Unknown option: $1" >&2
            usage 1
            ;;
        *)
            echo "Unexpected argument: $1" >&2
            usage 1
            ;;
    esac
done

# Detect dev instance. If the dev config exists and the dev launcher
# socket is present, default to targeting the dev instance. This
# prevents accidentally upgrading a production installation.
USE_DEV=false
if [ "$FORCE_PROD" = false ] && [ -f "$DEV_CONFIG_FILE" ]; then
    # shellcheck source=../deploy/dev/config
    source "$DEV_CONFIG_FILE"
    DEV_RUN_DIR="$BUREAU_DEV_RUN_DIR"
    DEV_DATA_DIR="$BUREAU_DEV_DATA_DIR"

    if [ -S "$DEV_RUN_DIR/launcher.sock" ]; then
        USE_DEV=true
    elif [ -f "$DEV_DATA_DIR/state/session.json" ]; then
        # Dev instance exists but isn't running. Still target it to
        # avoid hitting prod, but warn.
        echo "Warning: dev instance exists but is not running." >&2
        echo "  Start it with: script/dev-up" >&2
        echo "  Or use --prod to target the system installation." >&2
        exit 1
    fi
fi

# Resolve credential file.
if [ -z "$CREDENTIAL_FILE" ]; then
    if [ "$USE_DEV" = true ]; then
        CREDENTIAL_FILE="$DEV_DATA_DIR/bureau-creds"
    else
        # Production: operator should have a credential file from their
        # environment bootstrap. Check common locations.
        for candidate in \
            "$HOME/.config/bureau/bureau-creds" \
            "/etc/bureau/bureau-creds"; do
            if [ -f "$candidate" ]; then
                CREDENTIAL_FILE="$candidate"
                break
            fi
        done
    fi
fi

if [ ! -f "$CREDENTIAL_FILE" ]; then
    echo "Error: credential file not found: $CREDENTIAL_FILE" >&2
    echo "  Set BUREAU_CREDENTIAL_FILE or pass --credential-file" >&2
    exit 1
fi

if [ "$USE_DEV" = true ]; then
    echo "Target: dev instance (fleet: $BUREAU_DEV_FLEET)"
else
    echo "Target: system installation"
fi

# Build bureau-host-env from the current worktree.
VERSION=$(git -C "$REPO_ROOT" describe --dirty --always 2>/dev/null || echo "unknown")
echo "Building bureau-host-env from $VERSION..."
HOST_ENV=$(nix build "$REPO_ROOT#bureau-host-env" --print-out-paths --no-link)
echo "Built: $HOST_ENV"

if [ "$DRY_RUN" = true ]; then
    echo ""
    echo "Dry run: would publish BureauVersion from $HOST_ENV"
    echo "  Daemon:   $(readlink -f "$HOST_ENV/bin/bureau-daemon")"
    echo "  Launcher: $(readlink -f "$HOST_ENV/bin/bureau-launcher")"
    echo "  Proxy:    $(readlink -f "$HOST_ENV/bin/bureau-proxy")"
    exit 0
fi

# Build the bureau CLI from the same worktree so the upgrade command
# matches the code that produced the host-env.
echo "Building bureau CLI..."
BUREAU_CLI=$(nix build "$REPO_ROOT#bureau" --print-out-paths --no-link)/bin/bureau

if [ ! -x "$BUREAU_CLI" ]; then
    echo "Error: bureau CLI not found at $BUREAU_CLI" >&2
    exit 1
fi

# Publish the BureauVersion state event. The running daemon picks this
# up via /sync, prefetches the store paths, compares content hashes,
# and performs the atomic exec() transition. Service binaries are
# resolved from the host-env path in the event, so sandbox binaries
# update automatically without symlink changes.
echo "Publishing BureauVersion..."
if [ "$USE_DEV" = true ]; then
    # For dev, bypass /etc/bureau/machine.conf (which points at the prod
    # fleet) by setting BUREAU_MACHINE_CONF to a nonexistent path. This
    # forces --local to fall through to the launcher session file, which
    # BUREAU_LAUNCHER_SESSION points at the dev instance's session.json.
    BUREAU_MACHINE_CONF=/dev/null/nonexistent \
    BUREAU_LAUNCHER_SESSION="$DEV_DATA_DIR/state/session.json" \
        "$BUREAU_CLI" machine upgrade --local \
        --host-env "$HOST_ENV" \
        --credential-file "$CREDENTIAL_FILE"
else
    "$BUREAU_CLI" machine upgrade --local \
        --host-env "$HOST_ENV" \
        --credential-file "$CREDENTIAL_FILE"

    # For prod: write the host-env marker and update symlinks.
    HOST_ENV_MARKER="/var/bureau/cache/current-host-env"
    if [ -d "$(dirname "$HOST_ENV_MARKER")" ] && [ -w "$(dirname "$HOST_ENV_MARKER")" ]; then
        echo "$HOST_ENV" > "$HOST_ENV_MARKER"
        echo "Host-env path written to $HOST_ENV_MARKER"
    fi

    if [ -d /var/bureau/bin ] && [ -w /var/bureau/bin ]; then
        UPDATED=0
        for binary in "$HOST_ENV"/bin/bureau*; do
            name=$(basename "$binary")
            ln -sf "$binary" "/var/bureau/bin/$name"
            UPDATED=$((UPDATED + 1))
        done
        echo "Updated $UPDATED symlinks in /var/bureau/bin"
    fi
fi
