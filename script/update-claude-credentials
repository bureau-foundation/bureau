#!/usr/bin/env bash
# Copyright 2026 The Bureau Authors
# SPDX-License-Identifier: Apache-2.0

# Copy the local Claude Code credential file to Bureau's cache so
# sandboxed agents can authenticate with a subscription account.
#
# Run after `claude login` or when switching accounts. The credential
# file contains an OAuth token pair (access + refresh) that Claude Code
# uses for API authentication. The refresh token allows the sandbox to
# renew the access token automatically.
#
# Usage:
#   script/update-claude-credentials
#   script/update-claude-credentials /path/to/.credentials.json

set -euo pipefail

CREDENTIAL_SOURCE="${1:-$HOME/.claude/.credentials.json}"
CREDENTIAL_DEST="/var/bureau/cache/claude-credentials.json"

if [[ ! -f "$CREDENTIAL_SOURCE" ]]; then
    echo "error: credential file not found: $CREDENTIAL_SOURCE" >&2
    echo "" >&2
    echo "Run 'claude login' first, or pass the path to your credential file:" >&2
    echo "  script/update-claude-credentials /path/to/.credentials.json" >&2
    exit 1
fi

# Verify the file looks like a Claude credential (basic sanity check).
if ! grep -q '"claudeAiOauth"' "$CREDENTIAL_SOURCE" 2>/dev/null; then
    echo "error: $CREDENTIAL_SOURCE does not look like a Claude credential file" >&2
    exit 1
fi

sudo cp "$CREDENTIAL_SOURCE" "$CREDENTIAL_DEST"
sudo chown bureau:bureau "$CREDENTIAL_DEST"
sudo chmod 600 "$CREDENTIAL_DEST"

echo "Updated $CREDENTIAL_DEST from $CREDENTIAL_SOURCE"
